      "versionNonce": 1420556182,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782243323227,
      "link": null,
      "locked": false,
      "text": "Print worker log lines occurring since and\nuntil relative human readable times.\n\nISO8601 has standards for this as well.\nThey're called Period and can be prefixed\nwith P but we can not require that for\nease of use. P1H and 1h should both be\nvalid.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "zbLUPN4SJxZNs20fn4PS7",
      "originalText": "Print worker log lines occurring since and until relative human readable times.\n\nISO8601 has standards for this as well. They're called Period and can be prefixed with P but we can not require that for ease of use. P1H and 1h should both be valid.",
      "autoResize": true,
      "lineHeight": 1.25
    },
