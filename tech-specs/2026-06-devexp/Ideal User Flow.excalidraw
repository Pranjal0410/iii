      "updated": 1782242340514,
      "link": null,
      "locked": false,
      "text": "Seamless transition from development to first\ntime single-instance deployment.\n\nAlso provides users with a clear mapping to\ndistributed deployments. ",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "MxclmBmOxPOfmYBrOSyS8",
      "originalText": "Seamless transition from development to first time single-instance deployment.\n\nAlso provides users with a clear mapping to distributed deployments. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "l0P6Tr0s-GW7gMyzgbUtE",
      "type": "rectangle",
      "x": 10525.416781451773,
      "y": 5621.239431902631,
      "width": 1517.315623965925,
      "height": 2073.937727602271,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
