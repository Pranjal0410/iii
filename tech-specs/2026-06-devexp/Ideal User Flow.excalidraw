      "updated": 1782315794551,
      "link": null,
      "locked": false,
      "text": "worker-compose.yaml - Example\n\nworkers:\n    # Example 1: A local worker completely defined in worker-compose.yaml\n    my-node-worker:\n        runtime:\n          base_image: docker.io/_/node/node:lts-alpine3.23\n          workspace: ./myNodeWorker\n        scripts:\n          install: 'npm install'\n          start: 'npm run start'\n\n    # Example 2: A local binary worker completely defined in worker-compose.yaml\n    my-binary-worker:\n        runtime:\n            base_image: docker.io/alpine/alpine:latest\n            workspace: ./my_binary_worker\n        scripts:\n            setup: 'apt-get update && apt-get install'\n            start: './target/release/my_binary_worker'\n\n    # Example 3: A local worker that keeps its own definition in its own iii.worker.yaml\n    # In all cases what should happen is workers ship with a iii.worker.yaml\n    # BUT any worker-compose.yaml configuration overrides what is in iii.worker.yaml.\n    my-other-worker:\n        runtime:\n            workspace: ./myOtherWorker\n        scripts:\n            start: 'npm run dev' # Overrides `start: 'npm run start'` in worker's iii.worker.yaml\n\n    # Example 4: Run two different copies of the observability worker\n    observability-grafana:\n        depends_on:\n            - config-worker\n        runtime:\n          package: workers.iii.dev/observability:latest\n        environment:\n            OTEL_URL: \"my.grafana.local\"\n        config:\n            path: config-worker:observability-dev-grafana # A path to config\n            # path: ./config.d/observability-dev.conf # A local path\n\n    observability-datadog:\n        depends_on:\n            - config-worker\n        runtime:\n          package: workers.iii.dev/observability:0.21.0 # Version pinned\n        environment:\n            OTEL_URL: \"remote.datadog.com/anthonyiscoding\"\n        # When config is not specified default to: 'config-worker:WORKERID'\n        # Here it would be 'config-worker:observability-datadog'\n        # These are still overrides though. If the observability package defined\n        # a local path to a config then that would still be used\n\n    # Example 5: A worker that needs other workers to start first\n    config-worker:\n        depends_on:\n            - state # Will start state before config-worker\n            - db # Will throw on no 'db' entry\n        runtime:\n          package: workers.iii.dev/config-worker:latest\n        env_file: # Specify one or more .env files\n            - .env.dev\n        environment:\n            # Prefer in order: actual env, env_files (lowest in list takes precedent).\n            # I believe this is the same as Docker. Check.\n            OTEL_SECRET: ${OTEL_SECRET}\n        config:\n            path: config-worker:observability-dev-grafana # A path to config\n            # path: ./config.d/observability-dev.conf # A local path\n\n    # Example 6: Two of the same worker added via `iii worker add --compose`\n    state:\n        # ...\n\n    state-2:\n        # ...\n\n",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "N6ogGRouU-GkXvHJBdUle",
      "originalText": "worker-compose.yaml - Example\n\nworkers:\n    # Example 1: A local worker completely defined in worker-compose.yaml\n    my-node-worker:\n        runtime:\n          base_image: docker.io/_/node/node:lts-alpine3.23\n          workspace: ./myNodeWorker\n        scripts:\n          install: 'npm install'\n          start: 'npm run start'\n\n    # Example 2: A local binary worker completely defined in worker-compose.yaml\n    my-binary-worker:\n        runtime:\n            base_image: docker.io/alpine/alpine:latest\n            workspace: ./my_binary_worker\n        scripts:\n            setup: 'apt-get update && apt-get install'\n            start: './target/release/my_binary_worker'\n\n    # Example 3: A local worker that keeps its own definition in its own iii.worker.yaml\n    # In all cases what should happen is workers ship with a iii.worker.yaml\n    # BUT any worker-compose.yaml configuration overrides what is in iii.worker.yaml.\n    my-other-worker:\n        runtime:\n            workspace: ./myOtherWorker\n        scripts:\n            start: 'npm run dev' # Overrides `start: 'npm run start'` in worker's iii.worker.yaml\n\n    # Example 4: Run two different copies of the observability worker\n    observability-grafana:\n        depends_on:\n            - config-worker\n        runtime:\n          package: workers.iii.dev/observability:latest\n        environment:\n            OTEL_URL: \"my.grafana.local\"\n        config:\n            path: config-worker:observability-dev-grafana # A path to config\n            # path: ./config.d/observability-dev.conf # A local path\n\n    observability-datadog:\n        depends_on:\n            - config-worker\n        runtime:\n          package: workers.iii.dev/observability:0.21.0 # Version pinned\n        environment:\n            OTEL_URL: \"remote.datadog.com/anthonyiscoding\"\n        # When config is not specified default to: 'config-worker:WORKERID'\n        # Here it would be 'config-worker:observability-datadog'\n        # These are still overrides though. If the observability package defined\n        # a local path to a config then that would still be used\n\n    # Example 5: A worker that needs other workers to start first\n    config-worker:\n        depends_on:\n            - state # Will start state before config-worker\n            - db # Will throw on no 'db' entry\n        runtime:\n          package: workers.iii.dev/config-worker:latest\n        env_file: # Specify one or more .env files\n            - .env.dev\n        environment:\n            # Prefer in order: actual env, env_files (lowest in list takes precedent).\n            # I believe this is the same as Docker. Check.\n            OTEL_SECRET: ${OTEL_SECRET}\n        config:\n            path: config-worker:observability-dev-grafana # A path to config\n            # path: ./config.d/observability-dev.conf # A local path\n\n    # Example 6: Two of the same worker added via `iii worker add --compose`\n    state:\n        # ...\n\n    state-2:\n        # ...\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
